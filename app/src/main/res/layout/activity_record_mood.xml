<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_white"
    android:orientation="vertical"
    tools:context=".RecordMoodActivity">

    <!-- 顶部导航 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="12dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/record_btn_next"
            android:padding="8dp"
            android:src="@drawable/ic_back" />

        <ImageView
            android:id="@+id/btn_close"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:contentDescription="@string/record_btn_skip"
            android:padding="8dp"
            android:src="@drawable/ic_close" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/tv_header_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            tools:text="2026年06月10日 今天 10:09" />

    </LinearLayout>

    <!-- 进度条 -->
    <FrameLayout
        android:id="@+id/progress_container"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="8dp">

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/shape_progress_track" />

        <View
            android:id="@+id/progress_fill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/shape_progress_fill" />

    </FrameLayout>

    <!-- 步骤内容区域 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/bg_warm_white">

        <!-- 步骤 1：心情打分 -->
        <LinearLayout
            android:id="@+id/step1_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_warm_white"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:visibility="visible">

            <TextView
                android:id="@+id/tv_step1_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:gravity="center"
                android:text="@string/record_step1_title"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="40dp"
                android:background="@drawable/shape_mood_pill_container"
                android:elevation="2dp"
                android:orientation="vertical"
                android:paddingVertical="4dp">

                <TextView
                    android:id="@+id/mood_option_0"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/selector_mood_option"
                    android:gravity="center"
                    android:text="@string/record_mood_very_good"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/divider_gray" />

                <TextView
                    android:id="@+id/mood_option_1"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/selector_mood_option"
                    android:gravity="center"
                    android:text="@string/record_mood_good"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/divider_gray" />

                <TextView
                    android:id="@+id/mood_option_2"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/selector_mood_option"
                    android:gravity="center"
                    android:text="@string/record_mood_normal"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/divider_gray" />

                <TextView
                    android:id="@+id/mood_option_3"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/selector_mood_option"
                    android:gravity="center"
                    android:text="@string/record_mood_bad"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginHorizontal="20dp"
                    android:background="@color/divider_gray" />

                <TextView
                    android:id="@+id/mood_option_4"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/selector_mood_option"
                    android:gravity="center"
                    android:text="@string/record_mood_very_bad"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <FrameLayout
                android:id="@+id/btn_step1_next"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/shape_next_pill_button">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/record_btn_next"
                    android:src="@drawable/ic_arrow_right_white" />

            </FrameLayout>

        </LinearLayout>

        <!-- 步骤 2：归因标签 -->
        <LinearLayout
            android:id="@+id/step2_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_warm_white"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_step2_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:paddingHorizontal="8dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="是什么让你觉得心情很好？" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_attribution"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="16dp"
                android:layout_weight="1"
                android:background="@color/bg_warm_white"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="8dp"
                tools:itemCount="12"
                tools:listitem="@layout/item_attribution_tag" />

            <FrameLayout
                android:id="@+id/btn_step2_next"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="24dp"
                android:background="@drawable/shape_next_pill_button">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/record_btn_next"
                    android:src="@drawable/ic_arrow_right_white" />

            </FrameLayout>

        </LinearLayout>

        <!-- 步骤 3：具体情绪 -->
        <LinearLayout
            android:id="@+id/step3_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_warm_white"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_step3_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center"
                android:text="@string/record_step3_title"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_search_emotion"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/shape_search_bg"
                android:drawableStart="@drawable/ic_search"
                android:drawablePadding="8dp"
                android:hint="@string/record_search_emotion"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_emotions"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="12dp"
                android:layout_weight="1"
                android:background="@color/bg_warm_white"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingBottom="8dp"
                tools:itemCount="18"
                tools:listitem="@layout/item_emotion_tag" />

            <FrameLayout
                android:id="@+id/btn_step3_next"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/shape_next_pill_button">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/record_btn_next"
                    android:src="@drawable/ic_arrow_right_white" />

            </FrameLayout>

            <TextView
                android:id="@+id/btn_step3_skip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:padding="8dp"
                android:text="@string/record_btn_skip"
                android:textColor="@color/theme_orange"
                android:textSize="15sp" />

        </LinearLayout>

        <!-- 步骤 4：详细记录 -->
        <RelativeLayout
            android:id="@+id/step4_layout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/bg_warm_white"
            android:paddingHorizontal="24dp"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/step4_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentTop="true"
                android:layout_marginTop="24dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_step4_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/record_step4_title"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_step4_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/record_step4_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

            </LinearLayout>

            <EditText
                android:id="@+id/et_detail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_above="@+id/step4_actions"
                android:layout_below="@id/step4_header"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:background="@color/bg_warm_white"
                android:gravity="top|start"
                android:hint="@string/record_hint_detail"
                android:importantForAutofill="no"
                android:imeOptions="actionDone|flagNoEnterAction"
                android:inputType="text|textMultiLine|textCapSentences"
                android:lineSpacingExtra="6dp"
                android:scrollbars="vertical"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="16sp" />

            <RelativeLayout
                android:id="@+id/step4_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="24dp">

                <ImageView
                    android:id="@+id/iv_upload_preview"
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_alignParentStart="true"
                    android:layout_marginBottom="12dp"
                    android:background="@drawable/shape_footprint_image"
                    android:contentDescription="@string/detail_image_desc"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />

                <ImageView
                    android:id="@+id/btn_gallery"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_alignParentStart="true"
                    android:layout_below="@id/iv_upload_preview"
                    android:background="@drawable/shape_gallery_btn"
                    android:contentDescription="@string/record_toast_gallery"
                    android:elevation="4dp"
                    android:padding="12dp"
                    android:src="@drawable/ic_gallery" />

                <ImageView
                    android:id="@+id/btn_save"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/shape_fab_circle"
                    android:contentDescription="@string/record_toast_saved"
                    android:elevation="4dp"
                    android:padding="14dp"
                    android:src="@drawable/ic_check_white" />

            </RelativeLayout>

        </RelativeLayout>

    </FrameLayout>

</LinearLayout>
