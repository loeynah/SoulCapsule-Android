<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_warm_white"
    android:orientation="vertical"
    tools:context=".EditMoodActivity">

    <!-- 顶部导航 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp">

        <TextView
            android:id="@+id/btn_cancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="@string/edit_mood_cancel"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/edit_mood_title"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/btn_done"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingVertical="8dp"
            android:text="@string/edit_mood_done"
            android:textColor="@color/theme_orange"
            android:textSize="15sp"
            android:textStyle="bold" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="20dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 心情选择 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/edit_mood_label_mood"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rg_mood"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <RadioButton
                    android:id="@+id/rb_mood_very_good"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/theme_orange"
                    android:paddingVertical="6dp"
                    android:text="@string/record_mood_very_good"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_mood_good"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/theme_orange"
                    android:paddingVertical="6dp"
                    android:text="@string/record_mood_good"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_mood_normal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/theme_orange"
                    android:paddingVertical="6dp"
                    android:text="@string/record_mood_normal"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_mood_bad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/theme_orange"
                    android:paddingVertical="6dp"
                    android:text="@string/record_mood_bad"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <RadioButton
                    android:id="@+id/rb_mood_very_bad"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/theme_orange"
                    android:paddingVertical="6dp"
                    android:text="@string/record_mood_very_bad"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

            </RadioGroup>

            <!-- 原因/标签 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/edit_mood_label_tags"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_tags"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_search_bg"
                android:hint="@string/edit_mood_hint_tags"
                android:importantForAutofill="no"
                android:inputType="text"
                android:paddingHorizontal="16dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

            <!-- 详细内容 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/edit_mood_label_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_content"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/shape_search_bg"
                android:gravity="top|start"
                android:hint="@string/record_hint_detail"
                android:importantForAutofill="no"
                android:imeOptions="actionDone|flagNoEnterAction"
                android:inputType="text|textMultiLine|textCapSentences"
                android:lineSpacingExtra="4dp"
                android:padding="16dp"
                android:scrollbars="vertical"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary"
                android:textSize="14sp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>
