<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"

    xmlns:tools="http://schemas.android.com/tools"

    android:layout_width="match_parent"

    android:layout_height="wrap_content"

    android:orientation="horizontal"

    android:paddingStart="12dp"

    android:paddingEnd="16dp"

    android:paddingBottom="20dp">



    <!-- 左侧日期区 -->

    <LinearLayout

        android:id="@+id/layout_date_header"

        android:layout_width="72dp"

        android:layout_height="wrap_content"

        android:gravity="center_horizontal"

        android:orientation="vertical"

        android:paddingTop="4dp">



        <TextView

            android:id="@+id/tv_year"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:textColor="@color/text_secondary"

            android:textSize="10sp"

            tools:text="2026年" />



        <TextView

            android:id="@+id/tv_date_month_day"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="2dp"

            android:textColor="@color/text_primary"

            android:textSize="22sp"

            android:textStyle="bold"

            tools:text="6.10" />



        <TextView

            android:id="@+id/tv_weekday"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="2dp"

            android:textColor="@color/text_secondary"

            android:textSize="11sp"

            tools:text="周三" />



    </LinearLayout>



    <!-- 中间时间轴区 -->

    <FrameLayout

        android:layout_width="24dp"

        android:layout_height="match_parent"

        android:layout_marginStart="4dp">



        <View

            android:id="@+id/view_timeline_line"

            android:layout_width="1dp"

            android:layout_height="match_parent"

            android:layout_gravity="center_horizontal"

            android:background="@color/divider_gray" />



        <View

            android:id="@+id/view_mood_dot"

            android:layout_width="12dp"

            android:layout_height="12dp"

            android:layout_gravity="center_horizontal|top"

            android:layout_marginTop="8dp"

            android:background="@drawable/shape_mood_dot_orange" />



    </FrameLayout>



    <!-- 右侧内容卡片 -->

    <LinearLayout

        android:layout_width="0dp"

        android:layout_height="wrap_content"

        android:layout_marginStart="8dp"

        android:layout_weight="1"

        android:orientation="vertical">



        <!-- 卡片顶部：心情 + 时间 -->

        <LinearLayout

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:gravity="center_vertical"

            android:orientation="horizontal">



            <TextView

                android:id="@+id/tv_mood_status"

                android:layout_width="0dp"

                android:layout_height="wrap_content"

                android:layout_weight="1"

                android:textColor="@color/text_primary"

                android:textSize="16sp"

                android:textStyle="bold"

                tools:text="心情一般" />



            <TextView

                android:id="@+id/tv_time"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:drawableEnd="@drawable/ic_chevron_right"

                android:drawablePadding="2dp"

                android:gravity="center_vertical"

                android:textColor="@color/text_secondary"

                android:textSize="12sp"

                tools:text="08:29" />



        </LinearLayout>



        <TextView

            android:id="@+id/tv_reason"

            android:layout_width="wrap_content"

            android:layout_height="wrap_content"

            android:layout_marginTop="10dp"

            android:background="@drawable/shape_reason_tag_bg"

            android:drawableStart="@drawable/ic_tag_default"

            android:drawablePadding="4dp"

            android:gravity="center_vertical"

            android:paddingHorizontal="10dp"

            android:paddingVertical="4dp"

            android:textColor="@color/text_primary"

            android:textSize="12sp"

            tools:text="工作" />



        <TextView

            android:id="@+id/tv_feelings"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="8dp"

            android:textColor="@color/text_secondary"

            android:textSize="13sp"

            tools:text="麻木" />



        <TextView

            android:id="@+id/tv_content"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="8dp"

            android:lineSpacingExtra="4dp"

            android:textColor="@color/text_primary"

            android:textSize="14sp"

            tools:text="今天完成了一个非常复杂的 3D 交互项目，还在寝室拼了一个可爱的模型，满满的成就感！" />



        <ImageView

            android:id="@+id/iv_image"

            android:layout_width="120dp"

            android:layout_height="120dp"

            android:layout_marginTop="12dp"

            android:background="@drawable/shape_footprint_image"

            android:contentDescription="@null"

            android:scaleType="centerCrop"

            android:visibility="gone"

            tools:visibility="visible" />



        <LinearLayout

            android:id="@+id/layout_ai_reply"

            android:layout_width="match_parent"

            android:layout_height="wrap_content"

            android:layout_marginTop="12dp"

            android:background="@drawable/shape_ai_reply_bg"

            android:orientation="vertical"

            android:padding="12dp"

            android:visibility="gone"

            tools:visibility="visible">



            <TextView

                android:id="@+id/tv_ai_reply"

                android:layout_width="match_parent"

                android:layout_height="wrap_content"

                android:lineSpacingExtra="4dp"

                android:textColor="@color/text_primary"

                android:textSize="13sp"

                tools:text="小旅：看见你在「学习」中感到「压抑」，我想先轻轻抱抱你。" />



            <TextView

                android:id="@+id/tv_ai_expand"

                android:layout_width="wrap_content"

                android:layout_height="wrap_content"

                android:layout_gravity="end"

                android:layout_marginTop="6dp"

                android:text="@string/footprint_expand"

                android:textColor="@color/theme_orange"

                android:textSize="12sp" />



        </LinearLayout>



    </LinearLayout>



</LinearLayout>

